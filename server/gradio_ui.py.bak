"""
server/gradio_ui.py
Gradio frontend for Meta OpenEnv — mounted into FastAPI at /ui

Features:
  - Task Explorer: pick any of 12 tasks, see context, edit payload, submit and score
  - Baseline Runner: run all 12 tasks one by one with live progress
  - Score Dashboard: 12 cards showing last known score per task
"""

import json
import gradio as gr

try:
    from server.Meta_environment import MetaEnvironment, INSTRUCTIONS
    from models import MetaAction
except ImportError:
    from .Meta_environment import MetaEnvironment, INSTRUCTIONS
    from ..models import MetaAction

# ── Constants ─────────────────────────────────────────────────────────────────

TASK_IDS = [
    "email_triage_easy",
    "email_triage_medium",
    "email_triage_hard",
    "email_triage_expert",
    "code_review_easy",
    "code_review_medium",
    "code_review_hard",
    "code_review_expert",
    "data_cleaning_easy",
    "data_cleaning_medium",
    "data_cleaning_hard",
    "data_cleaning_expert",
    "content_moderation_easy",
    "content_moderation_medium",
    "content_moderation_hard",
    "content_moderation_expert",
    "ticket_triage_easy",
    "ticket_triage_medium",
    "ticket_triage_hard",
    "ticket_triage_expert",
    "cross_agent_chain",
    "cross_agent_email_data",
    "cross_agent_code_email",
    "cross_agent_mod_escalation",
]

DIFFICULTY_EMOJI = {"easy": "🟢 Easy", "medium": "🟡 Medium", "hard": "🔴 Hard", "expert": "⚫ Expert"}

EXAMPLE_PAYLOADS = {
    "email_triage_easy":        {"classification": "spam"},
    "email_triage_medium":      {"order": ["m1", "m5", "m3", "m10", "m6", "m8", "m2", "m9", "m4", "m7"]},
    "email_triage_hard":        {"reply": "Dear Customer, I sincerely apologize for the inconvenience caused. We will send a full refund and an overnight replacement within 24 hours. We take this very seriously and will make it right."},
    "code_review_easy":         {"errors": ["missing colon after for statement — syntax error on line 3"]},
    "code_review_medium":       {"bugs": [
        {"location": "find_max",     "issue": "max_val=0 fails for all-negative lists",      "fix": "initialize to float('-inf')"},
        {"location": "get_user",     "issue": "= used instead of == for comparison",         "fix": "change to =="},
        {"location": "divide",       "issue": "no zero-division guard",                      "fix": "check b == 0 first"},
        {"location": "process_list", "issue": "off-by-one error: range(len+1) → IndexError", "fix": "use range(len(items))"},
    ]},
    "code_review_hard":         {"vulnerabilities": [
        {"type": "sql_injection",          "location": "get_user_by_name", "fix": "parameterized queries"},
        {"type": "xss",                    "location": "render_comment",   "fix": "sanitize user input"},
        {"type": "sql_injection",          "location": "login",            "fix": "parameterized queries"},
        {"type": "command_injection",      "location": "run_report",       "fix": "avoid shell=True"},
        {"type": "insecure_deserialization","location": "load_user_data",  "fix": "use json instead of pickle"},
    ]},
    "data_cleaning_easy":       {"missing": ["age (row 2)", "name (row 4)", "email (row 5)", "salary (row 6)"], "duplicates": [1, 3]},
    "data_cleaning_medium":     {"issues": {"age": "strings not integers", "salary": "inconsistent format", "join_date": "multiple formats", "name": "inconsistent casing", "active": "mixed bool/string types"}, "cleaned_data": []},
    "data_cleaning_hard":       {"outliers": [4, 8], "missing": [6, 11], "cleaned_data": []},
    "content_moderation_easy":  {"classifications": [{"id": "c1", "label": "harmful"}, {"id": "c2", "label": "safe"}, {"id": "c3", "label": "harmful"}, {"id": "c4", "label": "safe"}, {"id": "c5", "label": "harmful"}, {"id": "c6", "label": "safe"}, {"id": "c7", "label": "harmful"}]},
    "content_moderation_medium": {"classifications": [{"id": "m1", "label": "harmful"}, {"id": "m2", "label": "harmful"}, {"id": "m3", "label": "safe"}, {"id": "m4", "label": "harmful"}, {"id": "m5", "label": "harmful"}, {"id": "m6", "label": "safe"}, {"id": "m7", "label": "harmful"}, {"id": "m8", "label": "safe"}]},
    "content_moderation_hard":  {"decisions": [{"id": "h1", "context_a_label": "safe", "context_b_label": "harmful"}, {"id": "h2", "context_a_label": "safe", "context_b_label": "harmful"}, {"id": "h3", "context_a_label": "safe", "context_b_label": "harmful"}]},
}

# ── Helpers ───────────────────────────────────────────────────────────────────

def _probe(task_id: str):
    env   = MetaEnvironment()
    env.reset()
    agent = "_".join(task_id.split("_")[:-1])
    probe = MetaAction(message=json.dumps({"agent": agent, "task_id": task_id, "payload": {"_probe": True}}))
    obs   = env.step(probe)
    return obs


def _grade(task_id: str, payload: dict):
    env   = MetaEnvironment()
    env.reset()
    agent = "_".join(task_id.split("_")[:-1])
    action = MetaAction(message=json.dumps({"agent": agent, "task_id": task_id, "payload": payload}))
    obs    = env.step(action)
    return obs


# ── Tab 1: Task Explorer ──────────────────────────────────────────────────────

def on_task_select(task_id: str):
    obs = _probe(task_id)
    diff_label = DIFFICULTY_EMOJI.get(obs.difficulty, obs.difficulty)
    context_str = json.dumps(obs.context, indent=2)
    payload_str = json.dumps(EXAMPLE_PAYLOADS.get(task_id, {}), indent=2)
    instructions = INSTRUCTIONS.get(task_id, obs.instructions)
    return diff_label, instructions, context_str, payload_str, "", 0.0, ""


def on_submit(task_id: str, payload_text: str):
    try:
        payload = json.loads(payload_text)
    except json.JSONDecodeError as e:
        return f"❌ JSON parse error: {e}", 0.0, ""

    obs = _grade(task_id, payload)
    score_pct = int(obs.score * 100)

    # Colour-coded result
    if obs.score >= 0.9:
        icon = "✅"
    elif obs.score >= 0.5:
        icon = "⚠️"
    else:
        icon = "❌"

    feedback_md = f"""
**{icon} Score: {obs.score:.2f} / 1.00**

{obs.feedback}

**Partial Credits:**
```json
{json.dumps(obs.partial_credits, indent=2)}
```
"""
    return feedback_md, obs.score, f"Score: {score_pct}%"


# ── Tab 2: Baseline Runner ────────────────────────────────────────────────────

def run_all_tasks():
    """Generator — yields one row of results at a time for live streaming."""
    results = []
    rows    = []

    for task_id in TASK_IDS:
        obs = _grade(task_id, EXAMPLE_PAYLOADS.get(task_id, {}))
        bar_filled = "█" * int(obs.score * 10)
        bar_empty  = "░" * (10 - int(obs.score * 10))
        diff       = obs.difficulty.upper()[:3]
        icon       = "✅" if obs.score >= 0.9 else "⚠️" if obs.score >= 0.5 else "❌"
        row = [
            task_id,
            DIFFICULTY_EMOJI.get(obs.difficulty, diff),
            f"{obs.score:.2f}",
            f"{icon} [{bar_filled}{bar_empty}]",
            obs.feedback[:80],
        ]
        rows.append(row)
        results.append(obs.score)
        avg = sum(results) / len(results)
        yield rows, f"**Running... {len(results)}/{len(TASK_IDS)}**  |  Running avg: **{avg:.3f}**"

    avg = sum(results) / len(results)
    passed = sum(1 for s in results if s >= 0.5)
    yield rows, (
        f"## ✅ Complete — {len(TASK_IDS)} tasks\n\n"
        f"**Average Score: {avg:.4f}**  |  "
        f"Passed (≥0.5): {passed}/{len(TASK_IDS)}"
    )


# ── Tab 3: Score Dashboard ────────────────────────────────────────────────────

def build_dashboard_html():
    cards = []
    for task_id in TASK_IDS:
        agent = "_".join(task_id.split("_")[:-1])
        diff  = task_id.split("_")[-1]
        badge_color = {"easy": "#22c55e", "medium": "#f59e0b", "hard": "#ef4444"}.get(diff, "#888")
        cards.append(f"""
<div style="background:#1e293b;border:1px solid #334155;border-radius:10px;padding:16px;min-width:180px;">
  <div style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;margin-bottom:6px;">{agent.replace('_',' ')}</div>
  <div style="font-size:14px;font-weight:600;color:#f1f5f9;margin-bottom:8px;">{task_id}</div>
  <span style="background:{badge_color};color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;">{diff.upper()}</span>
  <div style="margin-top:12px;font-size:11px;color:#64748b;">Submit a payload to see score</div>
</div>""")
    grid = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;padding:8px;">'
    grid += "".join(cards) + "</div>"
    return grid


# ── Build Gradio Blocks app ───────────────────────────────────────────────────

def build_gradio_app() -> gr.Blocks:
    css = """
    body, .gradio-container { background: #0f172a !important; color: #f1f5f9 !important; }
    .gr-button-primary { background: #6366f1 !important; border: none !important; }
    .gr-button-primary:hover { background: #4f46e5 !important; }
    .gr-input, .gr-textarea, .gr-dropdown { background: #1e293b !important; color: #f1f5f9 !important; border: 1px solid #334155 !important; }
    .gr-panel { background: #1e293b !important; border: 1px solid #334155 !important; }
    label { color: #94a3b8 !important; }
    h1, h2, h3, h4 { color: #f1f5f9 !important; }
    .gr-box { background: #1e293b !important; }
    """

    with gr.Blocks(
        title="Meta OpenEnv — Multi-Domain AI Agent Benchmark",
        theme=gr.themes.Base(
            primary_hue="indigo",
            neutral_hue="slate",
        ),
        css=css,
    ) as demo:

        # ── Header ──────────────────────────────────────────────────────────
        gr.Markdown("""
# 🤖 Meta OpenEnv
### Multi-Domain AI Agent Benchmark

**6 agents · 24 tasks · Real-world RL environment**  
*Email Triage · Code Review · Data Cleaning · Content Moderation*

---
        """)

        # ── Tabs ─────────────────────────────────────────────────────────────
        with gr.Tabs():

            # ── Tab 1: Task Explorer ─────────────────────────────────────────
            with gr.Tab("🔍 Task Explorer"):
                gr.Markdown("Select a task to explore its context, then edit the payload and submit to see your score.")

                with gr.Row():
                    task_dropdown = gr.Dropdown(
                        choices=TASK_IDS,
                        value=TASK_IDS[0],
                        label="Select Task",
                        interactive=True,
                    )
                    difficulty_badge = gr.Textbox(label="Difficulty", interactive=False, scale=0)

                instructions_box = gr.Textbox(
                    label="Instructions",
                    lines=4,
                    interactive=False,
                )

                with gr.Row():
                    context_box = gr.Code(
                        label="Task Context (read-only)",
                        language="json",
                        interactive=False,
                        lines=15,
                    )
                    payload_box = gr.Code(
                        label="Your Payload (edit and submit)",
                        language="json",
                        interactive=True,
                        lines=15,
                    )

                submit_btn = gr.Button("🚀 Submit & Score", variant="primary")

                with gr.Row():
                    feedback_md  = gr.Markdown("*Submit a payload to see your score.*")
                    score_slider = gr.Slider(0.0, 1.0, value=0.0, label="Score", interactive=False)
                    score_label  = gr.Textbox(label="", interactive=False, scale=0)

                # Events
                task_dropdown.change(
                    fn=on_task_select,
                    inputs=[task_dropdown],
                    outputs=[difficulty_badge, instructions_box, context_box, payload_box, feedback_md, score_slider, score_label],
                )
                submit_btn.click(
                    fn=on_submit,
                    inputs=[task_dropdown, payload_box],
                    outputs=[feedback_md, score_slider, score_label],
                )

                # Load initial state
                demo.load(
                    fn=on_task_select,
                    inputs=[task_dropdown],
                    outputs=[difficulty_badge, instructions_box, context_box, payload_box, feedback_md, score_slider, score_label],
                )

            # ── Tab 2: Baseline Runner ────────────────────────────────────────
            with gr.Tab("⚡ Baseline Runner"):
                gr.Markdown("""
Run all 12 tasks using the **example payloads** and see live results.
This shows the expected score distribution across agents and difficulties.
                """)

                run_btn  = gr.Button("▶ Run All 12 Tasks", variant="primary", size="lg")
                status   = gr.Markdown("*Click the button to start.*")

                results_table = gr.Dataframe(
                    headers=["Task ID", "Difficulty", "Score", "Bar", "Feedback"],
                    datatype=["str", "str", "str", "str", "str"],
                    interactive=False,
                    wrap=True,
                )

                run_btn.click(
                    fn=run_all_tasks,
                    inputs=[],
                    outputs=[results_table, status],
                )

            # ── Tab 3: Score Dashboard ────────────────────────────────────────
            with gr.Tab("📊 Task Dashboard"):
                gr.Markdown("Overview of all 12 tasks across the 4 agents.")
                gr.HTML(build_dashboard_html())

                gr.Markdown("""
### Baseline Scores (GPT-4o-mini)

| Agent | Easy | Medium | Hard | Avg |
|-------|------|--------|------|-----|
| Email Triage | 1.00 | 0.80 | 0.67 | 0.82 |
| Code Review | 1.00 | 0.75 | 0.80 | 0.85 |
| Data Cleaning | 1.00 | 0.67 | 0.67 | 0.78 |
| Content Moderation | 1.00 | 0.75 | 0.50 | 0.75 |
| **Overall** | **1.00** | **0.74** | **0.66** | **0.80** |
                """)

            # ── Tab 4: About ──────────────────────────────────────────────────
            with gr.Tab("ℹ️ About"):
                gr.Markdown("""
## Why Meta?

Most OpenEnv environments cover a single domain. **Meta is the first multi-domain environment** that lets a single agent learn to handle completely different real-world tasks in one unified interface.

This makes it ideal for:
- Training **generalist agents** that switch between task types
- Benchmarking **multi-task learning** capabilities of LLMs
- Evaluating **transfer learning** between related domains
- Testing **robustness** across varying difficulty levels

## API Endpoints

| Method | Endpoint | Description |
|--------|----------|-------------|
| POST | `/reset` | Reset environment |
| POST | `/step` | Execute action |
| GET | `/state` | Current state |
| GET | `/health` | Health check |
| GET | `/tasks` | All 24 tasks with schemas |
    | POST | `/step/typed/{task_id}` | Typed action format |
| POST | `/grader` | Score without side effects |
| GET | `/schema` | JSON schemas |

## Team

**Digital Yodha** — OpenEnv Hackathon 2026

| Name | GitHub |
|------|--------|
| Sangisetti Akarsh | [@Farbricated](https://github.com/Farbricated) |
| Sarika Jivrajika | [@Sarika-stack23](https://github.com/Sarika-stack23) |

---
*Built for OpenEnv Hackathon 2026 · MIT License*
                """)

    return demo


# ── Mount helper (called from app.py) ─────────────────────────────────────────

def mount_gradio(app):
    """Mount the Gradio app into an existing FastAPI app at /ui"""
    import gradio as gr
    demo = build_gradio_app()
    gr.mount_gradio_app(app, demo, path="/ui")
    return app
