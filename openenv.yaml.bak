spec_version: 1
name: Meta
description: >
  Meta is the first multi-domain OpenEnv environment featuring 5 AI agents (plus expert tier)
  (Email Triage, Code Review, Data Cleaning, Content Moderation, Ticket Triage)
  across 15 real-world tasks (easy/medium/hard) plus 4 cross-agent chained tasks.
  Built for multi-task learning, transfer learning, and generalist agent research.
  v3.0: deterministic context loading, harder hard tasks (8 vulnerabilities,
  adversarial content moderation), 5th domain, 4 cross-agent chained tasks.
version: "3.1.0"
type: space
runtime: fastapi
app: server.app:app
port: 7860

tags:
  - openenv
  - multi-agent
  - rl
  - workplace
  - benchmark
  - email-triage
  - code-review
  - data-cleaning
  - content-moderation
  - ticket-triage
  - cross-agent

tasks:
  # ── Email Triage ──────────────────────────────────────────────────────────
  - id: email_triage_easy
    agent: email_triage
    difficulty: easy
    description: Classify a single email as spam, important, or newsletter.

  - id: email_triage_medium
    agent: email_triage
    difficulty: medium
    description: Prioritize 10 workplace emails by urgency (most to least urgent).

  - id: email_triage_hard
    agent: email_triage
    difficulty: hard
    description: Draft a professional, empathetic reply to a complex customer complaint.

  # ── Code Review ───────────────────────────────────────────────────────────
  - id: code_review_easy
    agent: code_review
    difficulty: easy
    description: Identify the syntax error(s) in a Python code snippet.

  - id: code_review_medium
    agent: code_review
    difficulty: medium
    description: Find all 4 logical bugs in the provided code and suggest fixes.

  - id: code_review_hard
    agent: code_review
    difficulty: hard
    description: >
      Detect all 8 security vulnerabilities: SQL injection (x2), XSS,
      command injection, insecure deserialization, timing attack,
      path traversal, and SSRF.

  # ── Data Cleaning ─────────────────────────────────────────────────────────
  - id: data_cleaning_easy
    agent: data_cleaning
    difficulty: easy
    description: Identify all missing values by field+row and detect duplicate rows.

  - id: data_cleaning_medium
    agent: data_cleaning
    difficulty: medium
    description: Fix 5 data type/format issues and return the cleaned dataset.

  - id: data_cleaning_hard
    agent: data_cleaning
    difficulty: hard
    description: >
      Detect outliers via IQR/z-score, identify missing values, impute them,
      and return the cleaned dataset.

  # ── Content Moderation ────────────────────────────────────────────────────
  - id: content_moderation_easy
    agent: content_moderation
    difficulty: easy
    description: Classify 7 posts as safe or harmful (explicit content).

  - id: content_moderation_medium
    agent: content_moderation
    difficulty: medium
    description: Detect subtle toxicity, sarcasm, and implicit hostility across 8 posts.

  - id: content_moderation_hard
    agent: content_moderation
    difficulty: hard
    description: >
      Context-aware moderation across 6 cases including adversarial dog-whistles
      and coordinated inauthentic behavior patterns. Same text, two contexts.

  # ── Ticket Triage (NEW) ───────────────────────────────────────────────────
  - id: ticket_triage_easy
    agent: ticket_triage
    difficulty: easy
    description: Classify a Jira-style support ticket by priority and category.

  - id: ticket_triage_medium
    agent: ticket_triage
    difficulty: medium
    description: Order 8 tickets by priority and assign each to the correct team.

  - id: ticket_triage_hard
    agent: ticket_triage
    difficulty: hard
    description: >
      Analyse 6 linked incident tickets: produce root cause analysis,
      ordered resolution steps, affected services list, and P1-P4 severity.


  # ── Expert tier (multi-step reasoning, frontier challenge) ────────────────
  - id: email_triage_expert
    agent: email_triage
    difficulty: expert
    description: >
      Draft an executive reply to a 4-week escalated enterprise complaint.
      Account metadata and engineering root cause provided. Requires multi-context
      synthesis and executive tone calibration. Frontier models score ~0.45.

  - id: code_review_expert
    agent: code_review
    difficulty: expert
    description: >
      Identify 8 subtle vulnerabilities: hardcoded secret, JWT none-algorithm attack,
      mass assignment, IDOR, YAML RCE deserialization, TOCTOU race condition,
      prototype pollution, and log injection. Frontier models score ~0.38.

  - id: data_cleaning_expert
    agent: data_cleaning
    difficulty: expert
    description: >
      Join two datasets, detect multi-type anomalies (duplicates, missing, outliers,
      zero-amounts), convert currencies to USD, compute per-rep revenue excluding
      invalid transactions. Frontier models score ~0.50.

  - id: content_moderation_expert
    agent: content_moderation
    difficulty: expert
    description: >
      Issue rulings on 5 genuinely contested cases: suicidal ideation,
      great-replacement rhetoric, conscientious objection policy debate,
      antisemitic satire framing, and health misinformation. Frontier models score ~0.40.

  - id: ticket_triage_expert
    agent: ticket_triage
    difficulty: expert
    description: >
      Produce a board-ready PIR from a 4h17m outage timeline. Requires identifying
      timeline gaps, 5+ specific action items, and quantified MTTR breakdown.
      Frontier models score ~0.50.

  # ── Cross-Agent Chained (NEW x3) ──────────────────────────────────────────
  - id: cross_agent_chain
    agent: cross_agent
    difficulty: hard
    description: Classify the email AND identify the code bug in the attachment.

  - id: cross_agent_email_data
    agent: cross_agent
    difficulty: hard
    description: Classify the email urgency AND identify+fix data quality issues in the attachment.

  - id: cross_agent_code_email
    agent: cross_agent
    difficulty: hard
    description: Identify the security vulnerability AND draft a professional disclosure email.

  - id: cross_agent_mod_escalation
    agent: cross_agent
    difficulty: hard
    description: Classify the content AND decide escalation AND draft a moderation notice.

agents:
  - id: email_triage
    tasks: [email_triage_easy, email_triage_medium, email_triage_hard, email_triage_expert]

  - id: code_review
    tasks: [code_review_easy, code_review_medium, code_review_hard, code_review_expert]

  - id: data_cleaning
    tasks: [data_cleaning_easy, data_cleaning_medium, data_cleaning_hard, data_cleaning_expert]

  - id: content_moderation
    tasks: [content_moderation_easy, content_moderation_medium, content_moderation_hard, content_moderation_expert]

  - id: ticket_triage
    tasks: [ticket_triage_easy, ticket_triage_medium, ticket_triage_hard, ticket_triage_expert]

  - id: cross_agent
    tasks: [cross_agent_chain, cross_agent_email_data, cross_agent_code_email, cross_agent_mod_escalation]

reward:
  range: [0.0, 1.0]
  partial_credit: true
  deterministic: true
  shaping:
    speed_bonus: 0.05        # perfect on first attempt
    improvement_bonus: 0.1   # scaled improvement on retry
    repeated_failure_penalty: -0.05

baseline:
  model: gpt-4o-mini
  average_score: 0.80
  scores:
    email_triage_easy: 1.00
    email_triage_medium: 0.80
    email_triage_hard: 0.67
    code_review_easy: 1.00
    code_review_medium: 0.75
    code_review_hard: 0.50
    data_cleaning_easy: 1.00
    data_cleaning_medium: 0.67
    data_cleaning_hard: 0.67
    content_moderation_easy: 1.00
    content_moderation_medium: 0.75
    content_moderation_hard: 0.42
    ticket_triage_easy: 1.00
    ticket_triage_medium: 0.70
    ticket_triage_hard: 0.50
    cross_agent_chain: 0.75
    cross_agent_email_data: 0.67
    cross_agent_code_email: 0.67
    cross_agent_mod_escalation: 0.83